#!/usr/bin/env bash
set -euo pipefail
source /usr/local/lib/erinos/common.sh

TOTAL_STEPS=7
LOG="/tmp/erinos-install.log"
: > "$LOG"

# ── Banner ────────────────────────────────────────────────────────────
banner "ErinOS Installer" "This will install ErinOS onto a disk with full-disk encryption."

# ── [1/7] Checking internet ──────────────────────────────────────────
step "Checking internet"
if ! ping -c 1 -W 3 archlinux.org &>/dev/null; then
  fail "No internet connection detected."
  if gum confirm "Open nmtui to configure WiFi?"; then
    nmtui
    if ! ping -c 1 -W 3 archlinux.org &>/dev/null; then
      fail "Still no internet. Exiting."
      exit 1
    fi
  else
    fail "Internet is required. Exiting."
    exit 1
  fi
fi
ok "Internet OK"

# ── [2/7] Select target disk ─────────────────────────────────────────
step "Select target disk"
echo ""
lsblk -d -o NAME,SIZE,MODEL -n | grep -v "^loop\|^sr\|^ram"
echo ""

DISKS=$(lsblk -d -o NAME -n | grep -v "^loop\|^sr\|^ram")
DISK=$(echo "$DISKS" | gum choose --header "Select target disk:")
DISK="/dev/${DISK}"

warn "WARNING: This will ERASE ${DISK} and encrypt it."
if ! gum confirm "Continue?"; then
  echo "Aborted."
  exit 0
fi

# ── [3/7] Disk encryption ────────────────────────────────────────────
step "Disk encryption"
while true; do
  PASS1=$(gum input --password --prompt "Encryption passphrase: ")
  PASS2=$(gum input --password --prompt "Confirm passphrase: ")
  if [[ "$PASS1" == "$PASS2" && -n "$PASS1" ]]; then
    break
  fi
  fail "Passphrases don't match or are empty. Try again."
done

# ── Clean slate for automated steps ──────────────────────────────────
clear
banner "ErinOS Installer"
echo ""
gum style --foreground $PINK --bold "[1/$TOTAL_STEPS] Checking internet"
ok "Internet OK"
echo ""
gum style --foreground $PINK --bold "[2/$TOTAL_STEPS] Select target disk"
ok "Target disk: ${DISK}"
echo ""
gum style --foreground $PINK --bold "[3/$TOTAL_STEPS] Disk encryption"
ok "Encryption passphrase set"

# ── [4/7] Partitioning & formatting ──────────────────────────────────
STEP=3
step "Partitioning & formatting"

_do_partitioning() {
  run_logged "Partitions created" bash -c "
    sgdisk --zap-all '${DISK}'
    sgdisk -n 1:0:+512M -t 1:ef00 -c 1:EFI '${DISK}'
    sgdisk -n 2:0:0     -t 2:8309 -c 2:cryptroot '${DISK}'
    blockdev --rereadpt '${DISK}'
    udevadm settle
    sleep 2
  "

  # Determine partition naming (nvme0n1p1 vs sda1)
  if [[ "${DISK}" == *"nvme"* || "${DISK}" == *"mmcblk"* ]]; then
    PART1="${DISK}p1"
    PART2="${DISK}p2"
  else
    PART1="${DISK}1"
    PART2="${DISK}2"
  fi

  echo -n "$PASS1" | cryptsetup luksFormat --batch-mode --type luks2 "$PART2" -
  echo -n "$PASS1" | cryptsetup open "$PART2" cryptroot -
  ok "Disk encrypted"

  run_logged "Filesystems formatted" bash -c "
    mkfs.fat -F32 ${PART1}
    mkfs.ext4 -q /dev/mapper/cryptroot
  "

  mount /dev/mapper/cryptroot /mnt
  mount --mkdir "$PART1" /mnt/boot
}
try_step "Partitioning & formatting" _do_partitioning

# ── [5/7] Installing base system ─────────────────────────────────────
step "Installing base system"

_do_install() {
  gum spin --spinner dot --title "Initializing pacman keyring..." -- \
    bash -c "pacman-key --init && pacman-key --populate archlinux" >/dev/null 2>&1

  bash -c 'yes "" | pacstrap -K /mnt \
      base linux linux-firmware amd-ucode \
      networkmanager openssh tmux avahi nss-mdns \
      sqlite ffmpeg git \
      base-devel openssl libyaml libffi zlib \
      ollama-rocm \
      gum jq' >/tmp/pacstrap.log 2>&1 &
  PID=$!

  SPIN='⠋⠙⠹⠸⠼⠴⠦⠧⠇⠏'
  IDX=0
  START=$SECONDS
  while kill -0 $PID 2>/dev/null; do
    CHAR="${SPIN:IDX:1}"
    IDX=$(( (IDX + 1) % ${#SPIN} ))
    ELAPSED=$(( SECONDS - START ))
    MINS=$(( ELAPSED / 60 ))
    SECS=$(( ELAPSED % 60 ))
    TIMESTAMP=$(printf '%dm%02ds' "$MINS" "$SECS")
    INSTALL=$(tail -50 /tmp/pacstrap.log 2>/dev/null | grep -oE '\( *[0-9]+/[0-9]+\) installing' | tail -1 || true)
    DOWNLOAD=$(tail -50 /tmp/pacstrap.log 2>/dev/null | grep -oE '\( *[0-9]+/[0-9]+\) downloading' | tail -1 || true)
    if [[ -n "$INSTALL" ]]; then
      NUM=$(echo "$INSTALL" | grep -oE '\( *[0-9]+/[0-9]+\)')
      printf '\r\033[K  \033[38;5;%sm%s\033[0m Installing packages %s [%s]' "$PINK" "$CHAR" "$NUM" "$TIMESTAMP"
    elif [[ -n "$DOWNLOAD" ]]; then
      NUM=$(echo "$DOWNLOAD" | grep -oE '\( *[0-9]+/[0-9]+\)')
      printf '\r\033[K  \033[38;5;%sm%s\033[0m Downloading packages %s [%s]' "$PINK" "$CHAR" "$NUM" "$TIMESTAMP"
    else
      printf '\r\033[K  \033[38;5;%sm%s\033[0m Resolving packages, please wait... [%s]' "$PINK" "$CHAR" "$TIMESTAMP"
    fi
    sleep 0.3
  done
  printf '\r\033[K'

  if ! wait $PID 2>/dev/null; then
    fail "Package installation failed:"
    tail -5 /tmp/pacstrap.log
    return 1
  fi

  ok "Base system installed"

  run_logged "Fstab generated" bash -c "genfstab -U /mnt >> /mnt/etc/fstab"

  run_logged "ErinOS application copied" cp -a /root/erinos /mnt/opt/erinos
  chmod +x /mnt/opt/erinos/bin/*

  # Copy scripts and shared library to installed system
  mkdir -p /mnt/usr/local/lib/erinos
  cp /usr/local/lib/erinos/common.sh /mnt/usr/local/lib/erinos/common.sh
  cp /usr/local/bin/erinos-firstboot /mnt/usr/local/bin/erinos-firstboot
  cp /usr/local/bin/erinos-console /mnt/usr/local/bin/erinos-console
  chmod 755 /mnt/usr/local/bin/erinos-firstboot /mnt/usr/local/bin/erinos-console

  # Load .env from USB config partition
  USB_ENV_LOADED=false
  for part in $(blkid -t TYPE=vfat -o device 2>/dev/null); do
    [[ "$part" == "${PART1}" ]] && continue
    USB_MNT=$(mktemp -d)
    if mount -o ro "$part" "$USB_MNT" 2>/dev/null; then
      if [[ -f "$USB_MNT/erinos/.env" ]]; then
        cp "$USB_MNT/erinos/.env" /mnt/opt/erinos/.env
        chmod 600 /mnt/opt/erinos/.env
        USB_ENV_LOADED=true
        ok "Configuration loaded from USB"
        umount "$USB_MNT"
        rmdir "$USB_MNT"
        break
      fi
      umount "$USB_MNT"
    fi
    rmdir "$USB_MNT" 2>/dev/null || true
  done

  if [[ "$USB_ENV_LOADED" != true ]]; then
    warn "No .env found on USB — you can create /opt/erinos/.env manually after boot"
  fi
}
try_step "Installing base system" _do_install

# ── [6/7] Configuring system ─────────────────────────────────────────
step "Configuring system"

LUKS_UUID=$(blkid -s UUID -o value "$PART2")

_do_configure() {
  CFG_HOSTNAME="erinos"
  CFG_KEYMAP="us"
  CFG_TIMEZONE="UTC"
  if [[ -f /mnt/opt/erinos/.env ]]; then
    CFG_HOSTNAME=$(grep '^HOSTNAME=' /mnt/opt/erinos/.env | cut -d= -f2)
    CFG_HOSTNAME="${CFG_HOSTNAME:-erinos}"
    CFG_KEYMAP=$(grep '^KEYMAP=' /mnt/opt/erinos/.env | cut -d= -f2)
    CFG_KEYMAP="${CFG_KEYMAP:-us}"
    CFG_TIMEZONE=$(grep '^TIMEZONE=' /mnt/opt/erinos/.env | cut -d= -f2)
    CFG_TIMEZONE="${CFG_TIMEZONE:-UTC}"
  fi

  arch-chroot /mnt /bin/bash >>"$LOG" 2>&1 <<CHROOT || { fail "System configuration failed"; tail -10 "$LOG"; return 1; }
set -euo pipefail

# Locale
echo "en_US.UTF-8 UTF-8" > /etc/locale.gen
locale-gen
echo "LANG=en_US.UTF-8" > /etc/locale.conf

# Timezone
ln -sf /usr/share/zoneinfo/${CFG_TIMEZONE} /etc/localtime
hwclock --systohc

# Hostname
echo "${CFG_HOSTNAME}" > /etc/hostname

# Login banner
echo "ErinOS (\l)" > /etc/issue

# Console
echo "KEYMAP=${CFG_KEYMAP}" > /etc/vconsole.conf

# Default wired connection (DHCP)
mkdir -p /etc/NetworkManager/system-connections
cat > /etc/NetworkManager/system-connections/Wired.nmconnection <<NMCON
[connection]
id=Wired
type=ethernet
autoconnect=true

[ipv4]
method=auto

[ipv6]
method=auto
NMCON
chmod 600 /etc/NetworkManager/system-connections/Wired.nmconnection

# Boot loader (systemd-boot)
bootctl install

mkdir -p /boot/loader/entries
cat > /boot/loader/loader.conf <<EOF
default erinos.conf
timeout 0
EOF

cat > /boot/loader/entries/erinos.conf <<EOF
title   ErinOS
linux   /vmlinuz-linux
initrd  /amd-ucode.img
initrd  /initramfs-linux.img
options rd.luks.name=${LUKS_UUID}=cryptroot root=/dev/mapper/cryptroot rw quiet loglevel=3
EOF

# Initramfs with sd-encrypt hook
sed -i 's/^HOOKS=.*/HOOKS=(base systemd autodetect microcode modconf kms keyboard sd-vconsole sd-encrypt block filesystems fsck)/' /etc/mkinitcpio.conf
mkinitcpio -P

# System user
useradd -r -m -d /opt/erinos -s /bin/bash erinos
chown -R erinos: /opt/erinos

# Install rbenv + ruby-build
su erinos -s /bin/bash -c 'git clone https://github.com/rbenv/rbenv.git /opt/erinos/.rbenv'
su erinos -s /bin/bash -c 'git clone https://github.com/rbenv/ruby-build.git /opt/erinos/.rbenv/plugins/ruby-build'

# Build Ruby 4.0.0 (no YJIT — skips Rust dependency)
su erinos -s /bin/bash -c 'export PATH="/opt/erinos/.rbenv/bin:/opt/erinos/.rbenv/shims:\$PATH" && RUBY_CONFIGURE_OPTS="--disable-yjit" rbenv install 4.0.0 && rbenv global 4.0.0'

# rbenv profile (for future logins)
printf 'export PATH="\$HOME/.rbenv/bin:\$HOME/.rbenv/shims:\$PATH"\neval "\$(rbenv init -)"\n' > /opt/erinos/.bash_profile
chown erinos: /opt/erinos/.bash_profile

# CLI wrapper
printf '#!/usr/bin/env bash\nexport PATH="/opt/erinos/.rbenv/bin:/opt/erinos/.rbenv/shims:\$PATH"\ncd /opt/erinos && exec bundle exec bin/erinos "\$@"\n' > /usr/local/bin/erinos
chmod 755 /usr/local/bin/erinos

# Bundle install
su erinos -s /bin/bash -c 'export PATH="/opt/erinos/.rbenv/bin:/opt/erinos/.rbenv/shims:\$PATH" && cd /opt/erinos && bundle config set --local path vendor/bundle && bundle install'

# Create models directory
mkdir -p /opt/erinos/models
chown erinos: /opt/erinos/models

# ── Systemd service files ───────────────────────────────────────────

cat > /etc/systemd/system/erinos-server.service <<EOF
[Unit]
Description=ErinOS API Server
After=network.target ollama.service

[Service]
Type=simple
User=erinos
WorkingDirectory=/opt/erinos
EnvironmentFile=/opt/erinos/.env
ExecStart=/usr/local/bin/erinos server
Restart=on-failure

[Install]
WantedBy=multi-user.target
EOF

cat > /etc/systemd/system/erinos-telegram.service <<EOF
[Unit]
Description=ErinOS Telegram Bot
After=erinos-server.service
Requires=erinos-server.service

[Service]
Type=simple
User=erinos
WorkingDirectory=/opt/erinos
EnvironmentFile=/opt/erinos/.env
ExecStart=/usr/local/bin/erinos telegram
Restart=on-failure

[Install]
WantedBy=multi-user.target
EOF

cat > /etc/systemd/system/erinos-scheduler.service <<EOF
[Unit]
Description=ErinOS Scheduler
After=erinos-server.service
Requires=erinos-server.service

[Service]
Type=simple
User=erinos
WorkingDirectory=/opt/erinos
EnvironmentFile=/opt/erinos/.env
ExecStart=/usr/local/bin/erinos scheduler
Restart=on-failure

[Install]
WantedBy=multi-user.target
EOF

cat > /etc/systemd/system/erinos-whisper.service <<EOF
[Unit]
Description=Whisper Speech-to-Text Server
After=network.target

[Service]
Type=simple
ExecStart=/usr/local/bin/whisper-server --port 8080 --model /opt/erinos/models/ggml-base.en.bin
Restart=on-failure

[Install]
WantedBy=multi-user.target
EOF

# Getty autologin on tty1 (root) for console status display
mkdir -p /etc/systemd/system/getty@tty1.service.d
cat > /etc/systemd/system/getty@tty1.service.d/autologin.conf <<'GETTY'
[Service]
ExecStart=
ExecStart=-/sbin/agetty --autologin root --noclear %I \$TERM
GETTY

# Root profile: console on tty1, normal shell on SSH
cat > /root/.bash_profile <<'EOF'
if [[ \$(tty) == /dev/tty1 ]]; then
  exec /usr/local/bin/erinos-console
fi
EOF

# Allow root SSH login
sed -i 's/^#PermitRootLogin.*/PermitRootLogin yes/' /etc/ssh/sshd_config

# Disable systemd-firstboot
systemctl mask systemd-firstboot

# ErinOS first-boot service
cat > /etc/systemd/system/erinos-firstboot.service <<'FIRSTBOOT'
[Unit]
Description=ErinOS First Boot Setup
After=network-online.target ollama.service
Wants=network-online.target
ConditionPathExists=!/opt/erinos/.onboard-done

[Service]
Type=oneshot
ExecStart=/usr/local/bin/erinos-firstboot
TimeoutStartSec=900

[Install]
WantedBy=multi-user.target
FIRSTBOOT

# mDNS
sed -i 's/^hosts:.*/hosts: mymachines mdns_minimal [NOTFOUND=return] resolve [!UNAVAIL=return] files dns/' /etc/nsswitch.conf

# Enable boot services
systemctl enable ollama.service
systemctl enable NetworkManager.service
systemctl enable sshd.service
systemctl enable avahi-daemon.service
systemctl enable erinos-firstboot.service
systemctl disable NetworkManager-wait-online.service

CHROOT

  ok "Boot loader installed"
  ok "Initramfs built"
  ok "Application configured"
}
try_step "Configuring system" _do_configure

# ── [7/7] Set root password ──────────────────────────────────────────
step "Set root password"
while true; do
  ROOT_PASS1=$(gum input --password --prompt "Root password: ")
  ROOT_PASS2=$(gum input --password --prompt "Confirm: ")
  if [[ "$ROOT_PASS1" == "$ROOT_PASS2" && -n "$ROOT_PASS1" ]]; then
    break
  fi
  fail "Passwords don't match or are empty. Try again."
done
echo "root:${ROOT_PASS1}" | arch-chroot /mnt chpasswd
ok "Root password set"

# ── Cleanup ───────────────────────────────────────────────────────────
umount -R /mnt
cryptsetup close cryptroot

# ── Success ───────────────────────────────────────────────────────────
reveal_logo
gum style --foreground $GREEN --bold "Installation complete!"
echo ""
gum style --foreground $PINK \
  "Remove the USB drive and reboot (type 'reboot')." \
  "You'll be prompted for your encryption passphrase on boot." \
  "ErinOS will finish setup automatically on first boot."
echo ""
