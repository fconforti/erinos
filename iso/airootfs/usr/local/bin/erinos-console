#!/usr/bin/env bash
# Console status display for ErinOS appliance (tty1 only).
# Shows SSH connection info, service health, and recent activity.
source /usr/local/lib/erinos/common.sh

c() { printf "\033[38;5;%sm" "$1"; }
RST='\033[0m'

activity_log() {
  {
    # Telegram messages and voice
    journalctl -u erinos-telegram --no-pager -o short-iso --since "-24h" 2>/dev/null \
      | grep -P 'telegram-bot: (Message from |Voice from |New conversation from |Starting bot|error:)' \
      | sed -n 's/.*\([0-9][0-9]-[0-9][0-9]\)T\([0-9][0-9]:[0-9][0-9]\).*telegram-bot: \(.*\)/\1 \2 \3/p'

    # SSH logins
    journalctl -u sshd --no-pager -o short-iso --since "-24h" 2>/dev/null \
      | grep 'Accepted' \
      | sed -n 's/.*\([0-9][0-9]-[0-9][0-9]\)T\([0-9][0-9]:[0-9][0-9]\).*Accepted [^ ]* for \([^ ]*\) from \([^ ]*\).*/\1 \2 SSH login as \3 from \4/p'

    # Ollama model activity
    journalctl -u ollama --no-pager -o short-iso --since "-24h" 2>/dev/null \
      | grep -E 'loading model|model loaded|model unloaded' \
      | sed -n 's/.*\([0-9][0-9]-[0-9][0-9]\)T\([0-9][0-9]:[0-9][0-9]\).*\(loading model\|model loaded\|model unloaded\).*/\1 \2 \3/p'

    # Scheduler activity
    journalctl -u erinos-scheduler --no-pager -o short-iso --since "-24h" 2>/dev/null \
      | grep '\[scheduler\] Fired' \
      | sed -n 's/.*\([0-9][0-9]-[0-9][0-9]\)T\([0-9][0-9]:[0-9][0-9]\).*\[scheduler\] \(.*\)/\1 \2 \3/p'

    # System boot
    journalctl -b --no-pager -o short-iso 2>/dev/null \
      | grep -m1 'Startup finished' \
      | sed -n 's/.*\([0-9][0-9]-[0-9][0-9]\)T\([0-9][0-9]:[0-9][0-9]\).*/\1 \2 System booted/p'

  } | sort -r | head -8 | while IFS= read -r line; do
    DATETIME="${line:0:11}"
    MSG="${line:12}"
    case "$MSG" in
      "Starting bot"*)   MSG="Telegram bot started" ;;
      "error:"*)         MSG="Error: ${MSG#error: }" ;;
      "loading model"*)  MSG="Loading AI model" ;;
      "model loaded"*)   MSG="AI model ready" ;;
      "model unloaded"*) MSG="AI model unloaded" ;;
    esac
    printf "$(c $DIM)%s${RST}  %s\n" "$DATETIME" "$MSG"
  done
}

# ── Network detection ─────────────────────────────────────────────────
IP=$(ip -4 -o addr show scope global 2>/dev/null | awk '{print $4}' | cut -d/ -f1 | head -1)

if [[ -z "$IP" ]]; then
  nmcli connection up Wired &>/dev/null \
    || nmcli device connect "$(nmcli -t -f DEVICE,TYPE device 2>/dev/null | grep ethernet | cut -d: -f1 | head -1)" &>/dev/null \
    || true
  sleep 3
  IP=$(ip -4 -o addr show scope global 2>/dev/null | awk '{print $4}' | cut -d/ -f1 | head -1)
fi

# ── Static content ───────────────────────────────────────────────────
clear

gum style --padding "1 0" --margin "1 0" \
  --foreground $PINK --bold "$LOGO"

if [[ -z "$IP" ]]; then
  printf "$(c $YELLOW)Waiting for network...${RST}\n"
fi
echo ""

MDNS_NAME="$(cat /etc/hostname 2>/dev/null || echo erinos).local"

# ── Dynamic content (refreshed every 10s) ────────────────────────────
while true; do
  tput sc

  if [[ -f /opt/erinos/.onboard-done ]]; then
    printf "$(c $GREEN)Setup complete.${RST}\n"
    echo ""
    if [[ -n "$IP" ]]; then
      printf "$(c $WHITE)ssh root@%s${RST}  $(c $DIM)(%s)${RST}\n" "$MDNS_NAME" "$IP"
    fi
    printf "Type $(c $PINK)erinos${RST} to interact with the appliance.\n"

    ACTIVITY=$(activity_log)
    if [[ -n "$ACTIVITY" ]]; then
      echo ""
      printf "$(c $WHITE)Activity log:${RST}\n"
      echo "$ACTIVITY"
    fi
  else
    STEP=$(cat /tmp/erinos-firstboot-status 2>/dev/null || echo "Starting setup...")
    printf "$(c $WHITE)Status:${RST} $(c $YELLOW)setting up${RST}\n"
    printf "$(c $DIM)%s${RST}\n" "$STEP"
  fi

  echo ""
  if [[ -f /opt/erinos/.onboard-done ]]; then
    sleep 10
  else
    sleep 3
  fi
  tput rc
  tput ed
done
