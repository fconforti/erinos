#!/usr/bin/env bash
# Non-interactive first-boot setup for ErinOS.
# Runs as a one-shot systemd service on first boot.
# Pulls the Ollama model, downloads whisper model, initializes DB, starts services.
set -euo pipefail

LOG="/tmp/erinos-firstboot.log"
STATUS="/tmp/erinos-firstboot-status"
: > "$LOG"

progress() { echo "$1" > "$STATUS"; }

export HOME="${HOME:-/root}"

ENV_FILE="/opt/erinos/.env"
source "$ENV_FILE" 2>/dev/null || true

ERIN_PROVIDER="${ERIN_PROVIDER:-ollama}"
ERIN_MODEL="${ERIN_MODEL:-}"

# ── Wait for DNS ─────────────────────────────────────────────────────
progress "Waiting for network..."
for _ in $(seq 1 60); do
  curl -fsSo /dev/null --max-time 3 https://ollama.com && break
  sleep 5
done

# ── Pull Ollama model ────────────────────────────────────────────────
if [[ "$ERIN_PROVIDER" == "ollama" && -n "$ERIN_MODEL" ]]; then
  progress "Waiting for Ollama..."
  for _ in $(seq 1 60); do
    ollama list &>/dev/null && break
    sleep 5
  done

  export OLLAMA_MAX_PARALLEL_DOWNLOADS="${OLLAMA_MAX_PARALLEL_DOWNLOADS:-2}"

  PULL_STATUS="/tmp/ollama-pull-status"
  START=$SECONDS
  for attempt in $(seq 1 5); do
    progress "Downloading ${ERIN_MODEL} (attempt ${attempt}/5)..."

    # Run ollama pull synchronously in a subshell with a 30-minute timeout.
    # Progress is captured via a background monitor.
    set +e
    timeout 1800 ollama pull "$ERIN_MODEL" 2>&1 | tee -a "$LOG" > "$PULL_STATUS" &
    PID=$!
    while kill -0 $PID 2>/dev/null; do
      ELAPSED=$(( SECONDS - START ))
      TIMESTAMP=$(printf '%dm%02ds' $((ELAPSED/60)) $((ELAPSED%60)))
      DETAIL=$(tr -d '\r' < "$PULL_STATUS" 2>/dev/null | grep -oE '[0-9]+%.*' | tail -1 || true)
      if [[ -n "$DETAIL" ]]; then
        progress "Downloading ${ERIN_MODEL}: ${DETAIL} [${TIMESTAMP}]"
      else
        progress "Downloading ${ERIN_MODEL}... [${TIMESTAMP}]"
      fi
      sleep 3
    done
    wait $PID
    PULL_EXIT=$?
    set -e

    # Verify the model is actually available, not just that the command exited
    if [[ $PULL_EXIT -eq 0 ]] && ollama list 2>/dev/null | grep -q "$(echo "$ERIN_MODEL" | cut -d: -f1)"; then
      break
    fi

    echo "Attempt ${attempt} failed (exit=$PULL_EXIT), retrying in 15s..." >> "$LOG"
    sleep 15
  done
  rm -f "$PULL_STATUS"
fi

# ── Download Whisper model ───────────────────────────────────────────
WHISPER_MODEL_PATH="/opt/erinos/models/ggml-base.en.bin"
if [[ ! -f "$WHISPER_MODEL_PATH" ]]; then
  progress "Downloading speech recognition model (whisper base.en, ~150MB)..."
  curl -fL --progress-bar 'https://huggingface.co/ggerganov/whisper.cpp/resolve/main/ggml-base.en.bin' \
    -o "$WHISPER_MODEL_PATH" >>"$LOG" 2>&1 || true
  chown erinos: "$WHISPER_MODEL_PATH"
  progress "Speech recognition model downloaded"
fi

# ── Initialize database ─────────────────────────────────────────────
progress "Initializing database..."
su erinos -s /bin/bash -c 'export PATH="/opt/erinos/.rbenv/bin:/opt/erinos/.rbenv/shims:$PATH" && cd /opt/erinos && bundle exec bin/erinos db:reset' >>"$LOG" 2>&1

# ── Install default skills ────────────────────────────────────────────
DEFAULT_SKILLS="${DEFAULT_SKILLS:-google}"
progress "Installing skills..."
IFS=',' read -ra SKILL_LIST <<< "$DEFAULT_SKILLS"
for skill in "${SKILL_LIST[@]}"; do
  skill=$(echo "$skill" | xargs)
  su erinos -s /bin/bash -c "export PATH=\"/opt/erinos/.rbenv/bin:/opt/erinos/.rbenv/shims:\$PATH\" && cd /opt/erinos && bundle exec ruby -e \"require_relative 'config/application'; SkillManager.new.install('$skill')\"" >>"$LOG" 2>&1 || true
done

# ── Start application services ───────────────────────────────────────
if [[ -f "$ENV_FILE" ]]; then
  progress "Starting services..."
  SERVICES="erinos-server erinos-whisper erinos-scheduler"
  if [[ -n "${TELEGRAM_BOT_TOKEN:-}" ]]; then
    SERVICES="$SERVICES erinos-telegram"
  fi
  if [[ -n "${TUNNEL_KEY:-}" ]]; then
    SERVICES="$SERVICES erinos-tunnel"
  fi
  systemctl enable $SERVICES >>"$LOG" 2>&1
  systemctl start $SERVICES >>"$LOG" 2>&1
else
  progress "No .env file found — skipping service startup"
  echo "WARNING: /opt/erinos/.env not found. Create it and run: systemctl start erinos-server" >>"$LOG"
fi

# ── Mark setup complete ──────────────────────────────────────────────
rm -f "$STATUS"
touch /opt/erinos/.onboard-done
chown erinos: /opt/erinos/.onboard-done
