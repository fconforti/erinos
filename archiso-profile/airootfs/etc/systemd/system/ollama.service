[Unit]
Description=Ollama local LLM inference server
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
User=erin
Environment=OLLAMA_HOST=127.0.0.1:11434
ExecStart=/usr/bin/ollama serve
Restart=on-failure
RestartSec=5
LimitNOFILE=65536

[Install]
WantedBy=multi-user.target
