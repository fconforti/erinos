# ─── ErinOS Configuration ───────────────────────────────────────────
# Copy this file to .env and fill in the values you need.
# The installer can also load this from a USB drive automatically.
# Lines starting with # are ignored. Remove or leave blank what you don't need.

# ─── System ─────────────────────────────────────────────────────────
# Used by the installer to configure the appliance.
# HOSTNAME=erinos
# TIMEZONE=Europe/Rome
# KEYMAP=us

# ─── Erin AI Model ──────────────────────────────────────────────────
# Provider: ollama (local), anthropic, openai, gemini, deepseek, mistral, openrouter
# If provider is "ollama", the model is pulled automatically on first boot.
ERIN_PROVIDER=ollama
ERIN_MODEL=qwen3:8b

# Provider API keys — only needed for cloud providers.
# ANTHROPIC_API_KEY=
# OPENAI_API_KEY=
# GEMINI_API_KEY=
# DEEPSEEK_API_KEY=
# MISTRAL_API_KEY=
# OPENROUTER_API_KEY=
OLLAMA_API_BASE=http://localhost:11434/v1

# ─── Relay ─────────────────────────────────────────────────────────
# Cloud relay for OAuth callbacks and remote access tunnel.
RELAY_URL=https://relay.erinos.ai
TUNNEL_KEY=

# ─── Voice ──────────────────────────────────────────────────────────
# Whisper (speech-to-text) and Kokoro (text-to-speech) URLs.
# Kokoro voices: af_heart, af_bella, am_adam, bf_emma, bm_george
WHISPER_URL=http://localhost:8080
KOKORO_URL=http://localhost:8880
KOKORO_VOICE=af_heart

# ─── Telegram ───────────────────────────────────────────────────────
# Get a token from @BotFather on Telegram.
# If left blank, the Telegram bot won't start.
TELEGRAM_BOT_TOKEN=
